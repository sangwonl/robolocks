{
  "name": "robolocks-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "build:wasm": "../scripts/build.sh wasm",
    "sync:wasm": "../scripts/build.sh sync",
    "gen:sdk": "node scripts/gen-python-sdk.mjs",
    "copy:pyodide": "node scripts/copy-pyodide.mjs",
    "predev": "npm run gen:sdk && npm run copy:pyodide",
    "prebuild": "npm run gen:sdk && npm run copy:pyodide",
    "pretest": "npm run gen:sdk",
    "pretypecheck": "npm run gen:sdk"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "pyodide": "0.26.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17"
  }
}
